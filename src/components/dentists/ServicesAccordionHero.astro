---
import ResponsiveImage from '../ResponsiveImage.astro';
const { practice } = Astro.props;
// Service-led blurbs for the expandable list — use the practice's own services.
const heroServices = practice.services.slice(0, 6);
---
<!-- HERO: services accordion — expandable treatment menu as the hero focus -->
<section class="sa-hero" style="position:relative; min-height:100vh; padding:120px 56px 80px; background:linear-gradient(180deg, var(--cream) 0%, var(--cream-2) 100%); overflow:hidden;">
  <div style="position:absolute; inset:0; background-image:radial-gradient(circle at 20% 20%, rgba(184,148,90,0.08) 0, transparent 50%), radial-gradient(circle at 80% 80%, rgba(184,148,90,0.06) 0, transparent 50%); pointer-events:none;"></div>
  <div class="sa-grid" style="position:relative; z-index:5; max-width:1320px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center;">
    <!-- Left: editorial intro + accordion -->
    <div>
      <div class="hero-text-1" style="font-size:10px; letter-spacing:0.35em; text-transform:uppercase; color:var(--gold-text); font-weight:500; margin-bottom:22px;">Treatment Menu · {practice.address.split(',').slice(-2,-1)[0].trim()}</div>
      <h1 class="hero-text-2" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-weight:300; font-size:clamp(48px,6vw,84px); line-height:1.02; color:var(--ink); margin:0 0 28px; white-space:pre-line;">{practice.hero.headline}</h1>
      <p class="hero-text-3" style="font-size:17px; line-height:1.85; color:var(--muted-text); margin:0 0 36px; max-width:480px; font-weight:300;">{practice.hero.subheadline} Open any treatment below for what's involved, who it's for, and what to expect.</p>

      <!-- Accordion -->
      <div class="hero-text-4 sa-accordion" style="border-top:1px solid rgba(184,148,90,0.25);">
        {heroServices.map((s, i) => (
          <details open={i === 0} class="sa-row" style="border-bottom:1px solid rgba(184,148,90,0.25);">
            <summary style="list-style:none; cursor:pointer; padding:18px 4px; display:flex; align-items:center; gap:18px;">
              <span class="sa-num" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:var(--gold-text); min-width:24px; letter-spacing:0.05em;">{String(i + 1).padStart(2, '0')}</span>
              <span style="font-family:'Cormorant Garamond',serif; font-size:24px; color:var(--ink); flex:1; font-weight:400; letter-spacing:0.005em;">{s.name}</span>
              <span class="sa-toggle" style="width:30px; height:30px; border:1px solid var(--gold); color:var(--gold-text); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; font-family:'Plus Jakarta Sans',sans-serif;">+</span>
            </summary>
            <div style="padding:0 4px 22px 42px; max-width:520px;">
              <p style="font-size:14.5px; line-height:1.75; color:var(--muted-text); margin:0 0 14px; font-weight:300;">{s.desc}</p>
              <a href="#appointment" style="font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:var(--gold-text); border-bottom:1px solid var(--gold); padding-bottom:3px; font-weight:500;">
                Inquire about {s.name.toLowerCase()} →
              </a>
            </div>
          </details>
        ))}
      </div>

      <div class="hero-text-4" style="margin-top:42px; display:flex; gap:22px; align-items:center; flex-wrap:wrap;">
        <a href="#appointment" class="cta-btn" style="background:var(--gold-text); color:white; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; padding:18px 42px; font-weight:500;">
          {practice.hero.ctaText}
        </a>
        <a href={`tel:${practice.phone}`} style="font-size:15px; color:var(--muted-text); display:flex; align-items:center; gap:12px; font-weight:300;">
          <span style="display:inline-block; width:24px; height:1px; background:var(--gold);"></span>
          {practice.phone}
        </a>
      </div>
    </div>

    <!-- Right: framed photo with overlay caption -->
    <div style="position:relative;">
      <div style="position:relative; overflow:hidden;">
        <ResponsiveImage src={practice.hero.image} alt={practice.name} widths={[640,1024,1920]} sizes="(min-width: 1024px) 50vw, 100vw" width={1600} height={1067} eager imgStyle="width:100%; aspect-ratio:4/5; object-fit:cover; display:block;" />
        <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(26,18,8,0.55) 0%, transparent 45%);"></div>
        <div style="position:absolute; bottom:32px; left:32px; right:32px; color:white;">
          <div style="font-size:10px; letter-spacing:0.32em; text-transform:uppercase; color:var(--gold-3); margin-bottom:10px;">Studio</div>
          <div style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:24px; line-height:1.3;">"Every smile begins with a conversation, not a chair."</div>
        </div>
      </div>
      <!-- Concierge bar -->
      <div style="margin-top:18px; background:white; padding:18px 22px; display:flex; align-items:center; gap:16px; box-shadow:0 12px 36px rgba(26,18,8,0.08);">
        <div style="width:44px; height:44px; border-radius:50%; background:var(--gold-text); display:flex; align-items:center; justify-content:center; color:white; font-family:'Cormorant Garamond',serif; font-size:20px;">C</div>
        <div style="flex:1;">
          <div style="font-size:10px; letter-spacing:0.22em; text-transform:uppercase; color:var(--gold-text); font-weight:500;">Concierge</div>
          <div style="font-size:13px; color:var(--ink); margin-top:2px;">Speak with a treatment coordinator — typically &lt; 4 hours.</div>
        </div>
      </div>
    </div>
  </div>
  <style>
    .sa-row[open] .sa-toggle { background: var(--gold-text); color: white; border-color: var(--gold-text); }
    .sa-row[open] .sa-toggle::after { content: ''; }
    .sa-row[open] .sa-toggle { font-size: 0; }
    .sa-row[open] .sa-toggle::before { content: '−'; font-size: 16px; line-height: 1; }
    .sa-row:hover summary { background: rgba(184,148,90,0.04); }
    summary::-webkit-details-marker { display: none; }
    @media (max-width: 900px) {
      .sa-grid { grid-template-columns: 1fr !important; gap: 56px !important; }
      .sa-hero { padding: 100px 24px 64px !important; }
    }
  </style>
</section>
