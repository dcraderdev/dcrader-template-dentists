---
const { practice } = Astro.props;

// Generate next 14 days for the day-picker.
const today = new Date();
const days = Array.from({ length: 14 }, (_, i) => {
  const d = new Date(today);
  d.setDate(today.getDate() + i);
  return {
    date: d.toISOString().slice(0, 10),
    weekday: d.toLocaleDateString('en-US', { weekday: 'short' }),
    day: d.getDate(),
    month: d.toLocaleDateString('en-US', { month: 'short' }),
    closed: d.getDay() === 0 || d.getDay() === 1, // Sun/Mon often closed
  };
});

// Static, plausible slot grid by general time-of-day.
const slots = ['8:00 AM','9:30 AM','11:00 AM','1:30 PM','3:00 PM','4:30 PM'];
const services = practice.services.slice(0, 6).map((s: any) => s.name);
---
<!-- HERO: booking widget — online appointment picker as the centerpiece -->
<section class="bw-hero" style="min-height:96vh; display:grid; grid-template-columns:1fr 1fr; position:relative; overflow:hidden; background:var(--cream);">
  <!-- Left: editorial context -->
  <div class="bw-left" style="display:flex; flex-direction:column; justify-content:center; padding:96px 56px 96px 80px; background:var(--cream); position:relative;">
    <div style="position:absolute; top:40px; left:40px; opacity:0.5;" class="leaf-sway">
      <svg width="60" height="90" viewBox="0 0 60 90" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M30,88 Q28,70 24,52 Q18,32 10,18 Q20,28 28,48 Q32,60 30,88Z" fill="var(--sage)" opacity="0.5"/>
        <path d="M30,88 Q32,68 38,50 Q44,32 54,18 Q44,28 36,50 Q32,62 30,88Z" fill="var(--sage)" opacity="0.35"/>
        <line x1="30" y1="88" x2="30" y2="10" stroke="var(--sage)" stroke-width="1.5" opacity="0.4"/>
      </svg>
    </div>

    <div class="fade-1" style="font-size:10px; letter-spacing:0.32em; text-transform:uppercase; color:var(--sage); margin-bottom:26px; font-weight:500;">
      Online Booking · Real-time availability
    </div>
    <h1 class="fade-2" style="font-size:clamp(40px,5vw,72px); line-height:1.08; color:var(--ink); margin:0 0 26px; font-style:italic; white-space:pre-line; font-weight:400;">Book your visit<br/>in three breaths.</h1>
    <div class="fade-2" style="width:40px; height:2px; background:var(--sage); margin-bottom:26px;"></div>
    <p class="fade-3" style="font-size:18px; line-height:1.85; color:var(--muted); margin:0 0 36px; max-width:440px; font-weight:300;">
      {practice.hero.subheadline} No phone tag, no waiting on hold — confirm your spot in under a minute.
    </p>

    <!-- Booking confidence list -->
    <div class="fade-4" style="padding-top:28px; border-top:1px solid var(--cream-3); display:grid; gap:14px;">
      {[
        ['Instant confirmation', 'see your slot the moment you tap it'],
        ['Reschedule any time', 'one-click change up to 24h ahead'],
        ['Insurance pre-check', "we'll verify before you arrive"],
        ['Text reminders', "we won't call unless you ask"],
      ].map(([k, v]) => (
        <div style="display:flex; gap:14px; align-items:flex-start;">
          <svg width="14" height="20" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0; margin-top:3px;">
            <path d="M7,18 Q5,12 2,7 Q4,9 7,14 Q10,9 12,7 Q9,12 7,18Z" fill="var(--sage)" opacity="0.85"/>
            <line x1="7" y1="18" x2="7" y2="2" stroke="var(--sage-2)" stroke-width="1" opacity="0.5"/>
          </svg>
          <div>
            <div style="font-family:'Source Serif 4',serif; font-size:15px; color:var(--ink); font-weight:500;">{k}</div>
            <div style="font-size:13px; color:var(--muted); margin-top:2px;">{v}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Right: booking widget -->
  <div class="bw-right" style="display:flex; align-items:center; justify-content:center; padding:96px 64px; background:linear-gradient(180deg, var(--mist, #E6EFE5) 0%, var(--cream-2) 100%); position:relative;">
    <div style="position:absolute; top:40px; right:40px; opacity:0.35;" class="leaf-sway">
      <svg width="50" height="70" viewBox="0 0 50 70" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M25,68 Q23,50 18,35 Q12,20 4,8 Q16,18 22,36 Q26,48 25,68Z" fill="var(--sage)"/>
        <line x1="25" y1="68" x2="25" y2="4" stroke="var(--sage-2)" stroke-width="1.2" opacity="0.6"/>
      </svg>
    </div>

    <form id="bw-booking" class="fade-3" action="#appointment" method="get" style="background:white; padding:34px 32px; box-shadow:0 24px 64px rgba(45,74,47,0.12); border:1px solid var(--cream-3); width:100%; max-width:480px; display:flex; flex-direction:column; gap:22px;">
      <div style="display:flex; align-items:center; justify-content:space-between;">
        <div>
          <div style="font-size:10px; letter-spacing:0.32em; text-transform:uppercase; color:var(--sage); font-weight:500;">Step 1 of 3</div>
          <div style="font-family:'Source Serif 4',serif; font-size:22px; color:var(--ink); margin-top:4px; font-style:italic;">Choose your day</div>
        </div>
        <div style="display:flex; gap:6px;">
          <span style="width:28px; height:3px; background:var(--sage-3);"></span>
          <span style="width:28px; height:3px; background:var(--cream-3);"></span>
          <span style="width:28px; height:3px; background:var(--cream-3);"></span>
        </div>
      </div>

      <!-- Day picker -->
      <div class="bw-days" style="display:grid; grid-template-columns:repeat(7, 1fr); gap:6px;">
        {days.map((d, i) => (
          <label class={`bw-day ${d.closed ? 'is-closed' : ''}`} style="cursor:pointer;">
            <input type="radio" name="day" value={d.date} disabled={d.closed} checked={i === 1} style="position:absolute; opacity:0; pointer-events:none;" />
            <div style="border:1px solid var(--cream-3); padding:8px 2px; text-align:center; transition:all 0.15s ease;">
              <div style="font-size:9px; letter-spacing:0.14em; text-transform:uppercase; color:var(--muted);">{d.weekday}</div>
              <div style="font-family:'Source Serif 4',serif; font-size:18px; color:var(--ink); margin-top:2px;">{d.day}</div>
            </div>
          </label>
        ))}
      </div>

      <!-- Time slots -->
      <div>
        <div style="font-size:10px; letter-spacing:0.32em; text-transform:uppercase; color:var(--sage); font-weight:500; margin-bottom:10px;">Available times</div>
        <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:8px;">
          {slots.map((t, i) => (
            <label class="bw-slot" style="cursor:pointer;">
              <input type="radio" name="slot" value={t} checked={i === 1} style="position:absolute; opacity:0; pointer-events:none;" />
              <div style="border:1px solid var(--cream-3); padding:10px 4px; text-align:center; font-size:13px; color:var(--ink); font-weight:500; transition:all 0.15s ease;">
                {t}
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- Service select -->
      <div>
        <label style="font-size:10px; letter-spacing:0.32em; text-transform:uppercase; color:var(--sage); font-weight:500; display:block; margin-bottom:8px;" for="bw-service">Reason for visit</label>
        <select id="bw-service" name="service" style="width:100%; padding:12px 14px; border:1px solid var(--cream-3); background:white; font-family:'Plus Jakarta Sans',sans-serif; font-size:14px; color:var(--ink); cursor:pointer;">
          {services.map((s: string) => <option value={s}>{s}</option>)}
          <option value="other">Something else</option>
        </select>
      </div>

      <button type="submit" class="cta-btn" style="background:var(--sage-3); color:white; font-size:12px; letter-spacing:0.16em; text-transform:uppercase; padding:18px 28px; font-weight:500; border:none; cursor:pointer; font-family:inherit;">
        Continue to confirm →
      </button>

      <div style="text-align:center; font-size:11px; color:var(--muted);">
        Or call <a href={`tel:${practice.phone}`} style="color:var(--sage-2); border-bottom:1px solid var(--sage); padding-bottom:1px;">{practice.phone}</a>
      </div>
    </form>
  </div>

  <style>
    .bw-day input:checked + div { background: var(--sage-3); color: white; border-color: var(--sage-3); }
    .bw-day input:checked + div > div { color: white !important; }
    .bw-day.is-closed > div { opacity: 0.3; cursor: not-allowed; }
    .bw-day:not(.is-closed):hover > div { border-color: var(--sage); background: rgba(79,124,86,0.05); }
    .bw-slot input:checked + div { background: var(--sage-3); color: white; border-color: var(--sage-3); }
    .bw-slot:hover > div { border-color: var(--sage); background: rgba(79,124,86,0.05); }
    #bw-service:focus { outline: none; border-color: var(--sage); }
    @media (max-width: 900px) {
      .bw-hero { grid-template-columns: 1fr !important; }
      .bw-left { padding: 72px 28px !important; }
      .bw-right { padding: 56px 24px 80px !important; }
    }
  </style>
</section>
