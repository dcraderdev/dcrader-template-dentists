---
import { practice } from '../../data/v3';
import ResponsiveImage from '../../components/ResponsiveImage.astro';

const heroBase = practice.hero.image.replace(/\.webp$/i, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{practice.name} | Digital Dentistry Seattle</title>
  <meta name="description" content={practice.tagline} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="preload" as="image" fetchpriority="high" href={`${heroBase}-1024.avif`} type="image/avif" imagesrcset={`${heroBase}-640.avif 640w, ${heroBase}-1024.avif 1024w, ${heroBase}.avif 1600w`} imagesizes="100vw" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    :root {
      --navy: #040D18;
      --navy-2: #071426;
      --navy-3: #0D1F38;
      --navy-4: #122844;
      --teal: #00DFD0;
      --teal-dim: rgba(0,223,208,0.12);
      --teal-glow: rgba(0,223,208,0.35);
      --teal-border: rgba(0,223,208,0.22);
      --white: #E8F4FF;
      --muted: #6B92B8;
      --muted-2: #4A6A88;
    }
    body { font-family: 'Sora', sans-serif; color: var(--white); background: var(--navy); margin: 0; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    a { text-decoration: none; }

    @keyframes glow-pulse {
      0%, 100% { box-shadow: 0 0 0 0 var(--teal-glow); }
      50% { box-shadow: 0 0 0 10px transparent; }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(22px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes scanDown {
      0% { top: -20%; opacity: 1; }
      80% { opacity: 0.6; }
      100% { top: 120%; opacity: 0; }
    }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
    @keyframes rotateSlow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-12px); } }

    .fade-1 { animation: fadeUp 0.8s ease both; }
    .fade-2 { animation: fadeUp 0.8s 0.1s ease both; }
    .fade-3 { animation: fadeUp 0.8s 0.2s ease both; }
    .fade-4 { animation: fadeUp 0.8s 0.3s ease both; }

    .grid-bg {
      background-image:
        linear-gradient(rgba(0,223,208,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,223,208,0.05) 1px, transparent 1px);
      background-size: 44px 44px;
    }

    .dot-pulse { animation: glow-pulse 2.5s ease infinite; }
    .tooth-float { animation: float 4s ease-in-out infinite; }

    .svc-card { transition: all 0.28s ease; border: 1px solid var(--teal-border); }
    .svc-card:hover { border-color: var(--teal); background: var(--teal-dim); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,223,208,0.1); }

    .tech-row { transition: all 0.25s ease; border-left: 2px solid var(--teal-border); }
    .tech-row:hover { border-left-color: var(--teal); background: var(--teal-dim); padding-left: 28px !important; }

    .team-card { transition: border-color 0.2s ease; border: 1px solid var(--teal-border); }
    .team-card:hover { border-color: var(--teal); }

    .book-cta { transition: all 0.2s ease; animation: glow-pulse 3s ease infinite; }
    .book-cta:hover { opacity: 0.88; transform: translateY(-2px); }

    input:focus, select:focus, textarea:focus { outline: none; border-color: var(--teal) !important; box-shadow: 0 0 0 2px var(--teal-dim); }
  </style>
</head>
<body>

<!-- NAV -->
<nav style="position:fixed; top:0; left:0; right:0; z-index:200; background:rgba(4,13,24,0.94); backdrop-filter:blur(20px); border-bottom:1px solid var(--teal-border); height:66px; display:flex; align-items:center; justify-content:space-between; padding:0 44px;">
  <div style="display:flex; align-items:center; gap:14px;">
    <div class="dot-pulse" style="width:9px; height:9px; background:var(--teal); border-radius:50%;"></div>
    <span class="mono" style="font-size:16px; font-weight:600; color:white; letter-spacing:0.02em;">{practice.name}</span>
    <span class="mono" style="font-size:11px; color:var(--muted); background:var(--navy-3); border:1px solid var(--teal-border); padding:2px 8px; border-radius:4px;">v3.0.0</span>
  </div>
  <div style="display:flex; gap:32px; align-items:center;">
    {[['#services','Services'],['#tech','Tech Stack'],['#team','Team'],['#contact','Contact']].map(([href,label]) => (
      <a href={href} class="mono" style="font-size:12px; color:var(--muted); font-weight:400; transition:color 0.15s; letter-spacing:0.04em;"
         onmouseover="this.style.color='var(--teal)'" onmouseout="this.style.color='var(--muted)'">{label}</a>
    ))}
    <a href="#appointment" class="book-cta" style="background:var(--teal); color:var(--navy); font-size:13px; font-weight:700; padding:10px 22px; border-radius:4px; font-family:'Sora',sans-serif; letter-spacing:0.03em;">
      Book a Scan →
    </a>
  </div>
</nav>

<!-- HERO -->
<section class="grid-bg" style="min-height:100vh; display:flex; flex-direction:column; justify-content:center; padding:100px 44px 80px; position:relative; overflow:hidden;">
  <!-- Teal radial glow -->
  <div style="position:absolute; top:-150px; right:-100px; width:700px; height:700px; background:radial-gradient(circle, rgba(0,223,208,0.1) 0%, transparent 65%); pointer-events:none;"></div>
  <div style="position:absolute; bottom:-100px; left:-50px; width:400px; height:400px; background:radial-gradient(circle, rgba(0,223,208,0.05) 0%, transparent 70%); pointer-events:none;"></div>

  <div style="max-width:1280px; margin:0 auto; width:100%; display:grid; grid-template-columns:1fr 420px; gap:80px; align-items:center;">
    <!-- Left: Text -->
    <div>
      <div class="fade-1 mono" style="font-size:12px; color:var(--teal); letter-spacing:0.14em; margin-bottom:20px; display:flex; align-items:center; gap:10px;">
        <span style="display:inline-block; width:20px; height:1px; background:var(--teal);"></span>
        // seattle · est. {practice.founded} · ai-assisted dentistry
      </div>
      <h1 class="fade-2" style="font-size:clamp(44px,5.5vw,80px); line-height:1.04; color:white; margin:0 0 24px; font-weight:800; white-space:pre-line;">{practice.hero.headline}</h1>
      <p class="fade-3" style="font-size:18px; line-height:1.78; color:var(--muted); margin:0 0 36px; max-width:500px; font-weight:300;">{practice.hero.subheadline}</p>

      <!-- CTA Buttons -->
      <div class="fade-4" style="display:flex; gap:14px; flex-wrap:wrap; align-items:center; margin-bottom:60px;">
        <a href="#appointment" class="book-cta" style="background:var(--teal); color:var(--navy); font-weight:700; font-size:15px; padding:16px 36px; border-radius:4px; display:flex; align-items:center; gap:8px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-2 .89-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.11-.89-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/></svg>
          {practice.hero.ctaText}
        </a>
        <a href="tel:{practice.phone}" class="mono" style="color:var(--teal); font-size:14px; border:1px solid var(--teal-border); padding:15px 22px; border-radius:4px; transition:border-color 0.2s;"
           onmouseover="this.style.borderColor='var(--teal)'" onmouseout="this.style.borderColor='var(--teal-border)'">{practice.phone}</a>
      </div>

      <!-- Stats -->
      <div class="fade-4" style="display:grid; grid-template-columns:repeat(3,1fr); gap:0; border:1px solid var(--teal-border); border-radius:6px; overflow:hidden;">
        {[['99.6%','Accuracy rate','CEREC same-day'],['< 2hr','Crown time','Digital workflow'],['3D CT','Guided implants','Sub-mm precision']].map(([n,l,sub], i) => (
          <div style={`padding:20px 22px; ${i < 2 ? 'border-right:1px solid var(--teal-border);' : ''} background:var(--navy-2);`}>
            <div class="mono" style="font-size:24px; color:var(--teal); font-weight:400; line-height:1;">{n}</div>
            <div style="font-size:12px; color:var(--white); font-weight:500; margin-top:6px;">{l}</div>
            <div class="mono" style="font-size:10px; color:var(--muted); margin-top:2px;">{sub}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Wireframe tooth SVG -->
    <div class="tooth-float" style="position:relative; display:flex; align-items:center; justify-content:center;">
      <svg viewBox="0 0 300 380" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%; max-width:380px; filter:drop-shadow(0 0 40px rgba(0,223,208,0.2));">
        <!-- Outer tooth shape -->
        <path d="M65,115 Q35,60 80,28 Q100,12 150,18 Q200,12 220,28 Q265,60 235,115 L224,280 Q218,328 192,328 Q174,328 150,298 Q126,328 108,328 Q82,328 76,280 Z"
              stroke="#00DFD0" stroke-width="1.5" opacity="0.75"/>
        <!-- Grid lines horizontal -->
        <line x1="68" y1="80" x2="232" y2="80" stroke="#00DFD0" stroke-width="0.5" opacity="0.25"/>
        <line x1="63" y1="135" x2="237" y2="135" stroke="#00DFD0" stroke-width="0.5" opacity="0.25"/>
        <line x1="65" y1="190" x2="235" y2="190" stroke="#00DFD0" stroke-width="0.5" opacity="0.25"/>
        <line x1="67" y1="245" x2="233" y2="245" stroke="#00DFD0" stroke-width="0.5" opacity="0.25"/>
        <line x1="72" y1="300" x2="228" y2="300" stroke="#00DFD0" stroke-width="0.5" opacity="0.2"/>
        <!-- Grid lines vertical -->
        <line x1="100" y1="20" x2="82" y2="325" stroke="#00DFD0" stroke-width="0.5" opacity="0.25"/>
        <line x1="150" y1="16" x2="150" y2="332" stroke="#00DFD0" stroke-width="0.5" opacity="0.25"/>
        <line x1="200" y1="20" x2="218" y2="325" stroke="#00DFD0" stroke-width="0.5" opacity="0.25"/>
        <!-- Cusp highlight points -->
        <circle cx="80" cy="56" r="4" fill="#00DFD0"/>
        <circle cx="115" cy="28" r="4" fill="#00DFD0"/>
        <circle cx="150" cy="20" r="5" fill="#00DFD0" opacity="0.9"/>
        <circle cx="185" cy="28" r="4" fill="#00DFD0"/>
        <circle cx="220" cy="56" r="4" fill="#00DFD0"/>
        <!-- Crown edge line -->
        <path d="M80,56 L115,28 L150,20 L185,28 L220,56" stroke="#00DFD0" stroke-width="1.5" opacity="0.9"/>
        <!-- Root tips -->
        <circle cx="110" cy="320" r="5" fill="#00DFD0" opacity="0.5"/>
        <circle cx="150" cy="328" r="5" fill="#00DFD0" opacity="0.7"/>
        <circle cx="190" cy="320" r="5" fill="#00DFD0" opacity="0.5"/>
        <!-- Root connector lines -->
        <path d="M108,290 Q110,310 110,320" stroke="#00DFD0" stroke-width="0.8" opacity="0.4"/>
        <path d="M150,290 Q150,312 150,328" stroke="#00DFD0" stroke-width="0.8" opacity="0.4"/>
        <path d="M192,290 Q190,310 190,320" stroke="#00DFD0" stroke-width="0.8" opacity="0.4"/>
        <!-- Inner detail arc (pulp chamber) -->
        <path d="M115,130 Q150,115 185,130 L185,200 Q150,220 115,200 Z" stroke="#00DFD0" stroke-width="0.8" fill="none" opacity="0.35"/>
        <!-- Measurement annotation lines -->
        <line x1="36" y1="28" x2="36" y2="328" stroke="#00DFD0" stroke-width="0.5" opacity="0.4" stroke-dasharray="3 4"/>
        <line x1="30" y1="28" x2="42" y2="28" stroke="#00DFD0" stroke-width="0.8" opacity="0.5"/>
        <line x1="30" y1="328" x2="42" y2="328" stroke="#00DFD0" stroke-width="0.8" opacity="0.5"/>
        <text x="10" y="182" font-family="JetBrains Mono, monospace" font-size="10" fill="#00DFD0" opacity="0.6">32mm</text>
        <!-- Apex indicator label -->
        <line x1="150" y1="340" x2="220" y2="358" stroke="#00DFD0" stroke-width="0.8" opacity="0.5"/>
        <text x="222" y="362" font-family="JetBrains Mono, monospace" font-size="10" fill="#00DFD0" opacity="0.7">apex.root</text>
        <!-- Crown label -->
        <line x1="150" y1="12" x2="222" y2="0" stroke="#00DFD0" stroke-width="0.8" opacity="0.5"/>
        <text x="225" y="4" font-family="JetBrains Mono, monospace" font-size="10" fill="#00DFD0" opacity="0.7">crown.ref</text>
      </svg>
      <!-- System status overlay -->
      <div style="position:absolute; bottom:20px; left:0; right:0; display:flex; justify-content:center;">
        <div style="background:rgba(4,13,24,0.88); border:1px solid var(--teal-border); padding:12px 18px; border-radius:6px; backdrop-filter:blur(8px);">
          <div class="mono" style="font-size:10px; color:var(--teal); margin-bottom:6px; letter-spacing:0.1em;">LIVE · SYSTEM STATUS</div>
          <div style="display:flex; gap:14px;">
            {['CEREC','AI Scan','3D CT','Laser'].map(t => (
              <div style="display:flex; align-items:center; gap:5px;">
                <div style="width:5px; height:5px; background:var(--teal); border-radius:50%;"></div>
                <span class="mono" style="font-size:10px; color:var(--muted);">{t}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- AI SCAN WIDGET -->
<section style="background:var(--navy-2); padding:80px 44px; border-top:1px solid var(--teal-border); border-bottom:1px solid var(--teal-border);">
  <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center;">
    <div>
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:16px;">// ai.scan.preview()</div>
      <h2 style="font-size:clamp(28px,3vw,44px); color:white; margin:0 0 16px; font-weight:700;">AI-Assisted Diagnosis</h2>
      <p style="font-size:16px; color:var(--muted); line-height:1.8; margin:0 0 32px; font-weight:300;">Our intraoral AI scanner processes 1,000+ data points per tooth, flagging early-stage issues invisible to the naked eye. Every scan is reviewed by your specialist.</p>
      <div style="display:flex; flex-direction:column; gap:14px;">
        {[['→ Instant cavity detection','Sub-millimeter accuracy across all surfaces'],['→ Gum health mapping','Periodontal pocket depth charted automatically'],['→ Bite force analysis','TMJ load distribution rendered in 3D'],['→ Bone density overlay','CT integration flags resorption before symptoms']].map(([title,sub]) => (
          <div style="display:flex; gap:14px; align-items:flex-start; padding:14px 16px; background:var(--navy-3); border-left:2px solid var(--teal); border-radius:0 6px 6px 0;">
            <div>
              <div class="mono" style="font-size:13px; color:var(--teal); font-weight:500;">{title}</div>
              <div style="font-size:12px; color:var(--muted); margin-top:3px;">{sub}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
    <!-- Fake scan widget -->
    <div style="position:relative; background:var(--navy-3); border:1px solid var(--teal-border); border-radius:8px; overflow:hidden; aspect-ratio:4/3;">
      <!-- Scanline animation -->
      <div style="position:absolute; left:0; right:0; height:2px; background:linear-gradient(to right, transparent, var(--teal), transparent); animation:scanDown 2.8s ease-in-out infinite; top:0;"></div>
      <ResponsiveImage src={practice.hero.image} alt="AI Scan" widths={[640,1024,1920]} sizes="100vw" width={1600} height={1067} eager imgStyle="width:100%; height:100%; object-fit:cover; opacity:0.45; display:block;" />
      <!-- Overlay grid -->
      <div style="position:absolute; inset:0; background-image:linear-gradient(rgba(0,223,208,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,223,208,0.06) 1px, transparent 1px); background-size:24px 24px;"></div>
      <!-- Detection boxes (fake) -->
      <div style="position:absolute; top:28%; left:38%; width:18%; height:16%; border:1.5px solid var(--teal); border-radius:2px;">
        <div class="mono" style="position:absolute; top:-18px; left:0; font-size:9px; color:var(--teal); background:var(--navy); padding:1px 6px; white-space:nowrap;">CAVITY_RISK: 0.87</div>
      </div>
      <div style="position:absolute; top:44%; left:57%; width:14%; height:12%; border:1.5px solid #22C55E; border-radius:2px;">
        <div class="mono" style="position:absolute; top:-18px; left:0; font-size:9px; color:#22C55E; background:var(--navy); padding:1px 6px; white-space:nowrap;">HEALTHY: 0.96</div>
      </div>
      <!-- Bottom status bar -->
      <div style="position:absolute; bottom:0; left:0; right:0; background:rgba(4,13,24,0.88); backdrop-filter:blur(6px); padding:10px 16px; display:flex; justify-content:space-between; align-items:center; border-top:1px solid var(--teal-border);">
        <div class="mono" style="font-size:10px; color:var(--teal);">● SCANNING</div>
        <div class="mono" style="font-size:10px; color:var(--muted);">TEETH_ANALYZED: 28 / 32</div>
        <div class="mono" style="font-size:10px; color:#22C55E;">CONFIDENCE: 99.6%</div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services" style="background:var(--navy); padding:100px 44px;">
  <div style="max-width:1280px; margin:0 auto;">
    <div style="margin-bottom:56px;">
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// services.list()</div>
      <h2 style="font-size:clamp(36px,4vw,60px); color:white; margin:0; font-weight:700;">What We Offer</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(290px,1fr)); gap:18px;">
      {practice.services.map(s => (
        <div class="svc-card" style="background:var(--navy-3); border-radius:8px; padding:28px;">
          <div style="font-size:26px; margin-bottom:14px;">{s.icon}</div>
          <h3 style="font-size:17px; color:white; margin:0 0 8px; font-weight:600;">{s.name}</h3>
          <p style="font-size:13px; color:var(--muted); line-height:1.75; margin:0; font-weight:300;">{s.desc}</p>
        </div>
      ))}
    </div>
    <div style="margin-top:40px; text-align:center;">
      <a href="#appointment" class="book-cta" style="display:inline-flex; align-items:center; gap:8px; background:var(--teal); color:var(--navy); font-size:15px; font-weight:700; padding:16px 36px; border-radius:4px;">
        Schedule Online Now →
      </a>
    </div>
  </div>
</section>

<!-- TECH STACK -->
<section id="tech" style="background:var(--navy-2); padding:100px 44px; border-top:1px solid var(--teal-border); border-bottom:1px solid var(--teal-border);">
  <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start;">
    <div>
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// tech.stack</div>
      <h2 style="font-size:clamp(32px,3.5vw,52px); color:white; margin:0 0 16px; font-weight:700;">Our Technology</h2>
      <p style="font-size:16px; color:var(--muted); line-height:1.8; margin:0 0 40px; font-weight:300;">We only deploy equipment that has clinical evidence behind it. No marketing gadgets. Every tool earns its place chairside.</p>
      <div style="display:flex; flex-direction:column; gap:2px;">
        {practice.techStack.map(t => (
          <div class="tech-row" style="padding:20px 18px; cursor:default; transition:all 0.25s ease; border-left:2px solid var(--teal-border);"
               onmouseover="this.style.borderLeftColor='var(--teal)'; this.style.paddingLeft='28px'; this.style.background='var(--teal-dim)'"
               onmouseout="this.style.borderLeftColor='var(--teal-border)'; this.style.paddingLeft='18px'; this.style.background='transparent'">
            <div style="font-size:15px; color:white; font-weight:600; margin-bottom:4px;">{t.name}</div>
            <div class="mono" style="font-size:12px; color:var(--teal); font-weight:300;">{t.desc}</div>
          </div>
        ))}
      </div>
    </div>
    <div style="display:flex; flex-direction:column; gap:14px;">
      <ResponsiveImage src={practice.hero.image} alt="Technology" widths={[320,640,1024,1920]} sizes="(min-width:1024px) 50vw, 100vw" width={1600} height={900} imgStyle="width:100%; aspect-ratio:16/9; object-fit:cover; border-radius:6px; border:1px solid var(--teal-border); display:block;" />
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
        {practice.officePhotos.slice(0,2).map(p => (
          <div>
            <ResponsiveImage src={p.url} alt={p.caption} widths={[320,640,1024]} sizes="(min-width:1024px) 33vw, 100vw" width={800} height={600} imgStyle="width:100%; aspect-ratio:4/3; object-fit:cover; border-radius:6px; border:1px solid var(--teal-border); display:block;" />
            <div class="mono" style="font-size:10px; color:var(--muted); margin-top:7px; letter-spacing:0.04em;">{p.caption}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- INSURANCE -->
<section style="background:var(--navy); padding:72px 44px;">
  <div style="max-width:1280px; margin:0 auto; text-align:center;">
    <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// insurance.accepted</div>
    <h2 style="font-size:clamp(28px,3vw,44px); color:white; margin:0 0 14px; font-weight:700;">Insurance & Coverage</h2>
    <p style="font-size:15px; color:var(--muted); max-width:460px; margin:0 auto 36px; font-weight:300;">We process most major PPO plans. We'll verify your benefits in under 5 minutes.</p>
    <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-bottom:32px;">
      {practice.insurance.map(ins => (
        <span class="mono" style="background:var(--navy-3); border:1px solid var(--teal-border); color:var(--muted); font-size:12px; padding:7px 18px; border-radius:4px;">{ins}</span>
      ))}
    </div>
    <a href="#appointment" class="book-cta" style="display:inline-flex; align-items:center; gap:8px; background:var(--teal); color:var(--navy); font-size:14px; font-weight:700; padding:14px 32px; border-radius:4px;">
      Verify My Coverage →
    </a>
  </div>
</section>

<!-- TEAM -->
<section id="team" style="background:var(--navy-2); padding:100px 44px;">
  <div style="max-width:1280px; margin:0 auto;">
    <div style="margin-bottom:56px;">
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// team.members()</div>
      <h2 style="font-size:clamp(36px,4vw,60px); color:white; margin:0; font-weight:700;">Our Specialists</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:20px;">
      {practice.team.map(m => (
        <div class="team-card" style="background:var(--navy-3); border-radius:8px; overflow:hidden; cursor:default;">
          <ResponsiveImage src={m.image} alt={m.name} widths={[320,640]} sizes="(min-width:1024px) 25vw, 50vw" width={480} height={480} imgStyle="width:100%; aspect-ratio:1/1; object-fit:cover; display:block; filter:grayscale(30%) brightness(0.9);" />
          <div style="padding:22px;">
            <div class="mono" style="font-size:10px; color:var(--teal); margin-bottom:7px; letter-spacing:0.08em;">{m.role}</div>
            <h3 style="font-size:17px; color:white; margin:0 0 10px; font-weight:600;">{m.name}</h3>
            <p style="font-size:13px; color:var(--muted); line-height:1.75; margin:0; font-weight:300;">{m.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BEFORE/AFTER -->
<section style="background:var(--navy); padding:100px 44px;">
  <div style="max-width:1280px; margin:0 auto;">
    <div style="margin-bottom:56px;">
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// results.compare()</div>
      <h2 style="font-size:clamp(36px,4vw,56px); color:white; margin:0; font-weight:700;">Clinical Results</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(520px,1fr)); gap:48px;">
      {practice.beforeAfter.map(ba => (
        <div>
          <div class="mono" style="font-size:13px; color:var(--teal); margin-bottom:14px; letter-spacing:0.04em;">{ba.label}</div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:3px;">
            <div>
              <div style="background:var(--navy-3); border:1px solid var(--teal-border); font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--muted); padding:5px 12px; letter-spacing:0.15em; text-transform:uppercase;">STATE::BEFORE</div>
              <ResponsiveImage src={ba.before} alt="Before" widths={[320,640,1024]} sizes="(min-width:1024px) 50vw, 100vw" width={800} height={600} imgStyle="width:100%; aspect-ratio:4/3; object-fit:cover; display:block; border:1px solid var(--teal-border); border-top:none;" />
            </div>
            <div>
              <div style="background:var(--teal); font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--navy); padding:5px 12px; letter-spacing:0.15em; text-transform:uppercase; font-weight:600;">STATE::AFTER</div>
              <ResponsiveImage src={ba.after} alt="After" widths={[320,640,1024]} sizes="(min-width:1024px) 50vw, 100vw" width={800} height={600} imgStyle="width:100%; aspect-ratio:4/3; object-fit:cover; display:block; border:1px solid var(--teal); border-top:none;" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- REVIEWS -->
<section style="background:var(--navy-2); padding:100px 44px;">
  <div style="max-width:1280px; margin:0 auto;">
    <div style="margin-bottom:56px;">
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// reviews.fetch(limit=4)</div>
      <h2 style="font-size:clamp(36px,4vw,56px); color:white; margin:0; font-weight:700;">Patient Reviews</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:20px;">
      {practice.reviews.map(r => (
        <div style="background:var(--navy-3); border:1px solid var(--teal-border); border-radius:8px; padding:28px; transition:border-color 0.2s ease;"
             onmouseover="this.style.borderColor='var(--teal)'" onmouseout="this.style.borderColor='var(--teal-border)'">
          <div class="mono" style="font-size:12px; color:var(--teal); margin-bottom:14px;">{'★'.repeat(r.stars)} · {r.date}</div>
          <p style="font-size:15px; color:var(--white); line-height:1.78; margin:0 0 20px; font-weight:300;">"{r.text}"</p>
          <div class="mono" style="font-size:12px; color:var(--muted);">— {r.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- LOCATION -->
<section id="contact" style="background:var(--navy); padding:100px 44px; border-top:1px solid var(--teal-border);">
  <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px;">
    <div>
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// location.get()</div>
      <h2 style="font-size:clamp(28px,3vw,44px); color:white; margin:0 0 40px; font-weight:700;">Find Us in Seattle</h2>
      <div style="display:flex; flex-direction:column; gap:22px;">
        {([['// address',practice.address],['// phone',practice.phone],['// email',practice.email]] as const).map(([l,v]) => (
          <div style="border-left:2px solid var(--teal-border); padding-left:18px;">
            <div class="mono" style="font-size:10px; color:var(--teal); margin-bottom:4px; letter-spacing:0.08em;">{l}</div>
            <div style="font-size:15px; color:var(--white); font-weight:400;">{v}</div>
          </div>
        ))}
      </div>
    </div>
    <div>
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// hours.schedule()</div>
      <h2 style="font-size:clamp(28px,3vw,44px); color:white; margin:0 0 32px; font-weight:700;">Office Hours</h2>
      <div style="display:flex; flex-direction:column;">
        {practice.hours.map(h => (
          <div style="display:flex; justify-content:space-between; align-items:center; padding:14px 0; border-bottom:1px solid var(--teal-border);">
            <span class="mono" style="font-size:13px; color:var(--muted);">{h.day}</span>
            <span class="mono" style="font-size:13px; color:var(--teal);">{h.time}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- APPOINTMENT -->
<section id="appointment" class="grid-bg" style="background:var(--navy-2); padding:100px 44px;">
  <div style="max-width:720px; margin:0 auto;">
    <div style="text-align:center; margin-bottom:52px;">
      <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// appointment.create()</div>
      <h2 style="font-size:clamp(32px,4vw,56px); color:white; margin:0 0 12px; font-weight:700;">Schedule a Scan</h2>
      <p style="font-size:16px; color:var(--muted); font-weight:300;">Online booking · Instant confirmation · No phone tag</p>
    </div>
    <form style="background:var(--navy-3); border:1px solid var(--teal-border); border-radius:8px; padding:44px; display:flex; flex-direction:column; gap:22px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
        <div>
          <label class="mono" style="display:block; font-size:10px; color:var(--teal); margin-bottom:9px; letter-spacing:0.1em; text-transform:uppercase;">FIRST_NAME</label>
          <input type="text" placeholder="Nathan" style="width:100%; padding:11px 14px; background:var(--navy); border:1px solid var(--teal-border); border-radius:4px; color:white; font-size:14px; font-family:'Sora',sans-serif; transition:all 0.2s;" />
        </div>
        <div>
          <label class="mono" style="display:block; font-size:10px; color:var(--teal); margin-bottom:9px; letter-spacing:0.1em; text-transform:uppercase;">LAST_NAME</label>
          <input type="text" placeholder="Kross" style="width:100%; padding:11px 14px; background:var(--navy); border:1px solid var(--teal-border); border-radius:4px; color:white; font-size:14px; font-family:'Sora',sans-serif; transition:all 0.2s;" />
        </div>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
        <div>
          <label class="mono" style="display:block; font-size:10px; color:var(--teal); margin-bottom:9px; letter-spacing:0.1em; text-transform:uppercase;">PHONE</label>
          <input type="tel" placeholder="(206) 555-0000" style="width:100%; padding:11px 14px; background:var(--navy); border:1px solid var(--teal-border); border-radius:4px; color:white; font-size:14px; font-family:'Sora',sans-serif; transition:all 0.2s;" />
        </div>
        <div>
          <label class="mono" style="display:block; font-size:10px; color:var(--teal); margin-bottom:9px; letter-spacing:0.1em; text-transform:uppercase;">EMAIL</label>
          <input type="email" placeholder="nathan@email.com" style="width:100%; padding:11px 14px; background:var(--navy); border:1px solid var(--teal-border); border-radius:4px; color:white; font-size:14px; font-family:'Sora',sans-serif; transition:all 0.2s;" />
        </div>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
        <div>
          <label class="mono" style="display:block; font-size:10px; color:var(--teal); margin-bottom:9px; letter-spacing:0.1em; text-transform:uppercase;">PREFERRED_DATE</label>
          <input type="date" style="width:100%; padding:11px 14px; background:var(--navy); border:1px solid var(--teal-border); border-radius:4px; color:white; font-size:14px; font-family:'JetBrains Mono',monospace; transition:all 0.2s;" />
        </div>
        <div>
          <label class="mono" style="display:block; font-size:10px; color:var(--teal); margin-bottom:9px; letter-spacing:0.1em; text-transform:uppercase;">SERVICE_TYPE</label>
          <select style="width:100%; padding:11px 14px; background:var(--navy); border:1px solid var(--teal-border); border-radius:4px; color:white; font-size:14px; font-family:'Sora',sans-serif; cursor:pointer; transition:all 0.2s;">
            <option value="">Select service</option>
            {practice.services.map(s => <option value={s.name}>{s.name}</option>)}
          </select>
        </div>
      </div>
      <div>
        <label class="mono" style="display:block; font-size:10px; color:var(--teal); margin-bottom:9px; letter-spacing:0.1em; text-transform:uppercase;">NOTES (OPTIONAL)</label>
        <textarea rows={3} placeholder="Any symptoms, questions, or relevant medical history..." style="width:100%; padding:11px 14px; background:var(--navy); border:1px solid var(--teal-border); border-radius:4px; color:white; font-size:14px; font-family:'Sora',sans-serif; resize:vertical; transition:all 0.2s;"></textarea>
      </div>
      <button type="submit" class="book-cta" style="background:var(--teal); color:var(--navy); font-size:14px; font-weight:700; padding:16px 28px; border:none; border-radius:4px; cursor:pointer; font-family:'Sora',sans-serif; display:flex; align-items:center; gap:8px; justify-content:center;">
        Submit Request →
      </button>
    </form>
  </div>
</section>

<!-- FOOTER + STATUS BAR -->
<footer style="background:var(--navy-2); border-top:1px solid var(--teal-border); padding:32px 44px; display:flex; justify-content:space-between; align-items:center;">
  <div style="display:flex; align-items:center; gap:10px;">
    <div style="width:7px; height:7px; background:var(--teal); border-radius:50%;"></div>
    <span class="mono" style="font-size:13px; color:var(--muted);">{practice.name}</span>
  </div>
  <span class="mono" style="font-size:11px; color:var(--muted-2);">© {new Date().getFullYear()} · All systems operational</span>
</footer>
<!-- VS Code status bar -->
<div style="background:#00DFD0; padding:4px 44px; display:flex; justify-content:space-between; align-items:center;">
  <div style="display:flex; gap:16px; align-items:center;">
    <span class="mono" style="font-size:10px; color:var(--navy); font-weight:600;">✓ {practice.name}</span>
    <span class="mono" style="font-size:10px; color:rgba(4,13,24,0.7);">Astro · TypeScript</span>
  </div>
  <div style="display:flex; gap:16px; align-items:center;">
    <span class="mono" style="font-size:10px; color:rgba(4,13,24,0.7);">{practice.address}</span>
    <span class="mono" style="font-size:10px; color:rgba(4,13,24,0.8); font-weight:600;">Book Online →</span>
  </div>
</div>

</body>
</html>
