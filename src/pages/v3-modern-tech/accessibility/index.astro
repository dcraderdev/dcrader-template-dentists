---
import { practice } from '../../../data/v3';
const accessibilityEmail = `accessibility@${practice.email.split('@')[1]}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Accessibility Statement | {practice.name}</title>
  <meta name="description" content={`Accessibility statement for ${practice.name}. We are committed to WCAG 2.1 Level AA compliance.`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root { --navy: #040D18; --navy-2: #071426; --teal: #00DFD0; --teal-dark: #00A89C; --white: #E8F4FF; --muted: #B0C8DC; }
    body { font-family: 'Sora', sans-serif; color: var(--white); background: var(--navy); margin: 0; line-height: 1.7; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    h1, h2 { color: white; }
    a { color: var(--teal); }
    a:focus-visible, button:focus-visible { outline: 3px solid var(--teal); outline-offset: 3px; }
    .skip-link { position: absolute; left: -9999px; top: 0; background: var(--teal); color: var(--navy); padding: 12px 18px; z-index: 9999; font-weight: 700; }
    .skip-link:focus { left: 0; }
  </style>
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <header style="background:var(--navy-2); border-bottom:1px solid rgba(0,223,208,0.22); padding:18px 44px;">
    <div style="max-width:960px; margin:0 auto; display:flex; justify-content:space-between; align-items:center;">
      <a href="/v3-modern-tech/" class="mono" style="font-size:15px; font-weight:600; color:white;">{practice.name}</a>
      <a href="/v3-modern-tech/" class="mono" style="font-size:13px; color:var(--teal);">&larr; back</a>
    </div>
  </header>
  <main id="main" style="max-width:760px; margin:0 auto; padding:64px 28px 96px;">
    <div class="mono" style="font-size:11px; color:var(--teal); letter-spacing:0.14em; margin-bottom:14px;">// accessibility.statement</div>
    <h1 style="font-size:clamp(34px,4vw,52px); margin:0 0 24px; font-weight:700;">Accessibility Statement</h1>
    <p style="font-size:17px; margin:0 0 20px;">
      {practice.name} is committed to ensuring digital accessibility for people of all abilities. We strive to conform to <abbr title="Web Content Accessibility Guidelines">WCAG</abbr> 2.1 Level AA standards and continuously improve the user experience for everyone.
    </p>
    <p style="font-size:17px; margin:0 0 32px;">
      If you experience any difficulty accessing this website, or need accommodations, please contact us at <a href={`mailto:${accessibilityEmail}`}>{accessibilityEmail}</a> or <a href={`tel:${practice.phone.replace(/[^0-9+]/g,'')}`}>{practice.phone}</a> and we will work to provide the information or service through alternative communication.
    </p>

    <h2 style="font-size:24px; margin:40px 0 14px;">Measures We Take</h2>
    <ul style="font-size:16px; color:var(--muted); padding-left:22px; margin:0 0 24px;">
      <li>Semantic HTML and proper heading hierarchy</li>
      <li>Descriptive alternative text for all meaningful images</li>
      <li>Keyboard navigation with visible focus indicators</li>
      <li>Color contrast meeting WCAG 2.1 AA ratios</li>
      <li>Form fields with associated labels</li>
      <li>Skip-to-content links and clear page landmarks</li>
      <li>Touch targets sized at least 44&times;44 pixels</li>
    </ul>

    <h2 style="font-size:24px; margin:40px 0 14px;">Ongoing Review</h2>
    <p style="font-size:16px; color:var(--muted); margin:0 0 16px;">
      This site is reviewed regularly. Last updated: <time datetime="2026-05-17">May 17, 2026</time>.
    </p>

    <h2 style="font-size:24px; margin:40px 0 14px;">Third-Party Content</h2>
    <p style="font-size:16px; color:var(--muted); margin:0 0 16px;">
      While we strive for full accessibility, some embedded third-party content may not be fully accessible. We will provide an accessible alternative on request.
    </p>

    <div style="margin-top:48px; padding:24px; background:var(--navy-2); border-left:3px solid var(--teal);">
      <strong style="display:block; color:white; margin-bottom:6px;">Need accommodations?</strong>
      <a href={`mailto:${accessibilityEmail}`}>{accessibilityEmail}</a> &middot; <a href={`tel:${practice.phone.replace(/[^0-9+]/g,'')}`}>{practice.phone}</a>
    </div>
  </main>
  <footer style="background:var(--navy-2); border-top:1px solid rgba(0,223,208,0.22); padding:24px 28px; text-align:center;">
    <span class="mono" style="font-size:12px; color:var(--muted);">&copy; {new Date().getFullYear()} {practice.name}. </span>
    <a href="/v3-modern-tech/" class="mono" style="font-size:12px;">home</a>
  </footer>
</body>
</html>
