---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dental Practice Templates — dcrader</title>
  <meta name="description" content="5 distinct dental practice landing page templates for client outreach." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: #0B0C10; color: #E8EAF0; margin: 0; }
    .card { transition: all 0.3s ease; }
    .card:hover { transform: translateY(-6px); }
    .card:hover .card-img { transform: scale(1.04); }
    .card-img { transition: transform 0.5s ease; }
    .preview-btn { transition: all 0.2s ease; }
    .preview-btn:hover { opacity: 0.85; transform: translateY(-1px); }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fade { animation: fadeUp 0.6s ease both; }
  </style>
</head>
<body>

<!-- HEADER -->
<header style="border-bottom:1px solid rgba(255,255,255,0.07); padding:32px 48px; display:flex; align-items:center; justify-content:space-between;">
  <div>
    <div style="font-family:'Playfair Display',serif; font-size:22px; color:white;">dcrader templates</div>
    <div style="font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#6B7280; margin-top:4px;">Industry Outreach Library</div>
  </div>
  <div style="display:flex; gap:24px; align-items:center;">
  </div>
</header>

<!-- HERO -->
<section style="padding:80px 48px 64px; max-width:1100px; margin:0 auto; text-align:center;">
  <div class="fade" style="display:inline-block; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); border-radius:9999px; padding:6px 20px; font-size:12px; letter-spacing:0.12em; text-transform:uppercase; color:#9CA3AF; margin-bottom:24px;">
    Dental Practice · 5 Variants
  </div>
  <h1 class="fade" style="font-family:'Playfair Display',serif; font-size:clamp(40px,5vw,72px); line-height:1.1; color:white; margin:0 0 20px;">
    Dentist Landing Page<br/>Template Library
  </h1>
  <p class="fade" style="font-size:18px; color:#9CA3AF; max-width:560px; margin:0 auto 16px; line-height:1.75;">
    Five production-ready landing pages for independent dental practices — each with a distinct identity, aesthetic, and target audience.
  </p>
  <p class="fade" style="font-size:14px; color:#6B7280; max-width:480px; margin:0 auto;">
    Built with Astro + Tailwind · Unsplash photos · Full appointment forms · Mobile-friendly
  </p>
</section>

<!-- VARIANT CARDS -->
<section style="padding:0 48px 96px; max-width:1300px; margin:0 auto;">
  <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(340px,1fr)); gap:28px;">
    {variants.map((v, i) => (
      <a href={`/${v.slug}`} class="card" style="display:block; border-radius:16px; overflow:hidden; border:1px solid rgba(255,255,255,0.08); background:#12141C; text-decoration:none; animation: fadeUp 0.6s {i * 0.08}s ease both;">
        <div style="position:relative; overflow:hidden; height:220px;">
          <img class="card-img" src={v.preview} alt={v.name} style="width:100%; height:100%; object-fit:cover; display:block;" />
          <div style={`position:absolute; inset:0; background:linear-gradient(to bottom, transparent 40%, rgba(18,20,28,0.85) 100%);`}></div>
          <div style={`position:absolute; top:16px; left:16px; background:${v.color}; color:white; font-size:11px; font-weight:700; padding:5px 14px; border-radius:9999px; letter-spacing:0.08em;`}>{v.label}</div>
          <div style="position:absolute; bottom:16px; left:16px; font-size:28px;">{v.emoji}</div>
        </div>
        <div style="padding:24px 28px 28px;">
          <div style="font-size:11px; letter-spacing:0.15em; text-transform:uppercase; color:#6B7280; margin-bottom:8px;">{v.city}</div>
          <h2 style="font-size:20px; font-weight:700; color:white; margin:0 0 8px;">{v.name}</h2>
          <p style="font-size:14px; color:#9CA3AF; margin:0 0 20px; line-height:1.6;">{v.tagline}</p>
          <div style={`display:inline-flex; align-items:center; gap:8px; background:${v.color}18; color:${v.color}; font-size:12px; font-weight:700; padding:8px 18px; border-radius:9999px; border:1px solid ${v.color}44;`}>
            View Template →
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- FOOTER -->
<footer style="border-top:1px solid rgba(255,255,255,0.06); padding:32px 48px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
  <div style="font-size:13px; color:#4B5563;">Built by <a href="https://dcrader.dev" style="color:#9CA3AF; text-decoration:none;">dcrader.dev</a> · Industry outreach template series</div>
  <div style="font-size:12px; color:#374151;">Astro · Tailwind · Vercel</div>
</footer>

</body>
</html>
