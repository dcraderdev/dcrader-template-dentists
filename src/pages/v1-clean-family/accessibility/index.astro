---
import { practice } from '../../../data/v1';
const accessibilityEmail = `accessibility@${practice.email.split('@')[1]}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Accessibility Statement | {practice.name}</title>
  <meta name="description" content={`Accessibility statement for ${practice.name}. We are committed to WCAG 2.1 Level AA compliance.`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --blue: #1A73E8;
      --blue-dark: #1557B0;
      --navy: #0F2D52;
      --text: #1C2B3A;
      --muted: #4A5968;
      --border: #DCE8F5;
      --sky: #E0F0FF;
    }
    body { font-family: 'Inter', sans-serif; color: var(--text); background: white; margin: 0; line-height: 1.65; }
    h1, h2, h3 { font-family: 'Source Serif 4', Georgia, serif; color: var(--navy); }
    a { color: var(--blue-dark); }
    a:focus-visible, button:focus-visible { outline: 3px solid var(--blue); outline-offset: 3px; }
    .skip-link { position: absolute; left: -9999px; top: 0; background: var(--navy); color: white; padding: 12px 18px; z-index: 9999; }
    .skip-link:focus { left: 0; }
  </style>
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <header style="background:white; border-bottom:1px solid var(--border); padding:18px 28px;">
    <div style="max-width:960px; margin:0 auto; display:flex; justify-content:space-between; align-items:center;">
      <a href="/v1-clean-family/" style="font-family:'Source Serif 4',serif; font-size:18px; font-weight:700; color:var(--navy);">{practice.name}</a>
      <a href="/v1-clean-family/" style="font-size:14px; color:var(--blue-dark); font-weight:600;">&larr; Back to home</a>
    </div>
  </header>
  <main id="main" style="max-width:760px; margin:0 auto; padding:64px 28px 96px;">
    <h1 style="font-size:clamp(34px,4vw,48px); margin:0 0 24px;">Accessibility Statement</h1>
    <p style="font-size:17px; color:var(--text); margin:0 0 20px;">
      {practice.name} is committed to ensuring digital accessibility for people of all abilities. We strive to conform to <abbr title="Web Content Accessibility Guidelines">WCAG</abbr> 2.1 Level AA standards and continuously improve the user experience for everyone.
    </p>
    <p style="font-size:17px; color:var(--text); margin:0 0 32px;">
      If you experience any difficulty accessing this website, or need accommodations, please contact us at <a href={`mailto:${accessibilityEmail}`}>{accessibilityEmail}</a> or <a href={`tel:${practice.phone.replace(/[^0-9+]/g,'')}`}>{practice.phone}</a> and we will work to provide the information or service through alternative communication.
    </p>

    <h2 style="font-size:24px; margin:40px 0 14px;">Measures We Take</h2>
    <ul style="font-size:16px; color:var(--muted); padding-left:22px; margin:0 0 24px;">
      <li>Semantic HTML and proper heading hierarchy throughout the site</li>
      <li>Descriptive alternative text for all meaningful images</li>
      <li>Keyboard navigation support with visible focus indicators</li>
      <li>Color contrast meeting WCAG 2.1 AA ratios (4.5:1 body, 3:1 large text and UI)</li>
      <li>Form fields with associated labels for assistive technologies</li>
      <li>Skip-to-content links and clear page landmarks</li>
      <li>Touch targets sized at least 44&times;44 pixels on interactive controls</li>
    </ul>

    <h2 style="font-size:24px; margin:40px 0 14px;">Ongoing Review</h2>
    <p style="font-size:16px; color:var(--muted); margin:0 0 16px;">
      This site is reviewed regularly. Last updated: <time datetime="2026-05-17">May 17, 2026</time>.
    </p>

    <h2 style="font-size:24px; margin:40px 0 14px;">Third-Party Content</h2>
    <p style="font-size:16px; color:var(--muted); margin:0 0 16px;">
      While we strive for full accessibility, some embedded third-party content (such as map widgets or video players) may not be fully accessible. We will provide an accessible alternative on request.
    </p>

    <div style="margin-top:48px; padding:24px; background:var(--sky); border-left:4px solid var(--blue); border-radius:6px;">
      <strong style="display:block; color:var(--navy); margin-bottom:6px;">Need accommodations?</strong>
      <a href={`mailto:${accessibilityEmail}`} style="color:var(--blue-dark);">{accessibilityEmail}</a> &middot; <a href={`tel:${practice.phone.replace(/[^0-9+]/g,'')}`} style="color:var(--blue-dark);">{practice.phone}</a>
    </div>
  </main>
  <footer style="background:var(--navy); color:rgba(255,255,255,0.7); padding:24px 28px; text-align:center; font-size:13px;">
    &copy; {new Date().getFullYear()} {practice.name}. <a href="/v1-clean-family/" style="color:white;">Home</a>
  </footer>
</body>
</html>
