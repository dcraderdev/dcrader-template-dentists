---
import { practice } from '../../../data/v2';
const accessibilityEmail = `accessibility@${practice.email.split('@')[1]}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Accessibility Statement | {practice.name}</title>
  <meta name="description" content={`Accessibility statement for ${practice.name}. We are committed to WCAG 2.1 Level AA compliance.`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root { --cream: #FAF7F2; --cream-2: #F2EBE0; --gold: #8E6E3F; --gold-dark: #6E5026; --ink: #1A1208; --muted: #5C5040; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; color: var(--ink); background: var(--cream); margin: 0; line-height: 1.7; }
    h1, h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 500; }
    a { color: var(--gold-dark); }
    a:focus-visible, button:focus-visible { outline: 3px solid var(--gold); outline-offset: 3px; }
    .skip-link { position: absolute; left: -9999px; top: 0; background: var(--ink); color: white; padding: 12px 18px; z-index: 9999; }
    .skip-link:focus { left: 0; }
  </style>
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <header style="background:var(--cream); border-bottom:1px solid var(--cream-2); padding:24px 56px;">
    <div style="max-width:960px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
      <a href="/v2-luxury-cosmetic/" style="font-family:'Cormorant Garamond',serif; font-size:20px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink);">{practice.name}</a>
      <a href="/v2-luxury-cosmetic/" style="font-size:13px; letter-spacing:0.1em; text-transform:uppercase; color:var(--gold-dark);">&larr; Home</a>
    </div>
  </header>
  <main id="main" style="max-width:760px; margin:0 auto; padding:64px 28px 96px;">
    <h1 style="font-size:clamp(40px,5vw,64px); margin:0 0 24px; font-style:italic; color:var(--ink);">Accessibility Statement</h1>
    <p style="font-size:17px; margin:0 0 20px;">
      {practice.name} is committed to ensuring digital accessibility for people of all abilities. We strive to conform to <abbr title="Web Content Accessibility Guidelines">WCAG</abbr> 2.1 Level AA standards and continuously improve the user experience for everyone.
    </p>
    <p style="font-size:17px; margin:0 0 32px;">
      If you experience any difficulty accessing this website, or need accommodations, please contact us at <a href={`mailto:${accessibilityEmail}`}>{accessibilityEmail}</a> or <a href={`tel:${practice.phone.replace(/[^0-9+]/g,'')}`}>{practice.phone}</a> and we will work to provide the information or service through alternative communication.
    </p>

    <h2 style="font-size:28px; margin:40px 0 14px;">Measures We Take</h2>
    <ul style="font-size:16px; color:var(--muted); padding-left:22px; margin:0 0 24px;">
      <li>Semantic HTML and proper heading hierarchy throughout the site</li>
      <li>Descriptive alternative text for all meaningful images</li>
      <li>Keyboard navigation support with visible focus indicators</li>
      <li>Color contrast meeting WCAG 2.1 AA ratios</li>
      <li>Form fields with associated labels for assistive technologies</li>
      <li>Skip-to-content links and clear page landmarks</li>
      <li>Touch targets sized at least 44&times;44 pixels on interactive controls</li>
    </ul>

    <h2 style="font-size:28px; margin:40px 0 14px;">Ongoing Review</h2>
    <p style="font-size:16px; color:var(--muted); margin:0 0 16px;">
      This site is reviewed regularly. Last updated: <time datetime="2026-05-17">May 17, 2026</time>.
    </p>

    <h2 style="font-size:28px; margin:40px 0 14px;">Third-Party Content</h2>
    <p style="font-size:16px; color:var(--muted); margin:0 0 16px;">
      While we strive for full accessibility, some embedded third-party content may not be fully accessible. We will provide an accessible alternative on request.
    </p>

    <div style="margin-top:48px; padding:24px; background:var(--cream-2); border-left:3px solid var(--gold);">
      <strong style="display:block; color:var(--ink); margin-bottom:6px;">Need accommodations?</strong>
      <a href={`mailto:${accessibilityEmail}`}>{accessibilityEmail}</a> &middot; <a href={`tel:${practice.phone.replace(/[^0-9+]/g,'')}`}>{practice.phone}</a>
    </div>
  </main>
  <footer style="background:var(--ink); color:rgba(255,255,255,0.75); padding:24px 28px; text-align:center; font-size:13px;">
    &copy; {new Date().getFullYear()} {practice.name}. <a href="/v2-luxury-cosmetic/" style="color:white;">Home</a>
  </footer>
</body>
</html>
