{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.(ico|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.(webp|avif|jpg|jpeg|png|gif|woff2|woff|ttf|otf|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "sunrisefamilydental.dcrader.dev"
        }
      ],
      "destination": "/v1-clean-family/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "elarasmilestudio.dcrader.dev"
        }
      ],
      "destination": "/v2-luxury-cosmetic/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "apexdigitaldental.dcrader.dev"
        }
      ],
      "destination": "/v3-modern-tech/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "smilesquadkids.dcrader.dev"
        }
      ],
      "destination": "/v4-pediatric-fun/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "rootandbranchdental.dcrader.dev"
        }
      ],
      "destination": "/v5-holistic-wellness/$1"
    }
  ]
}
